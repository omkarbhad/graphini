  GEMINI_API_KEY,
  OPENAI_API_KEY,
  OPEN_ROUTER_BASE_URL,
  OPEN_ROUTER_KEY
} from '$env/static/private';
import {
  convertGeminiFunctionCallToOpenAI,
  convertValidToolsToGemini,
  createGeminiClient,
  geminiStreamResponse,
  isGeminiModel
} from '$lib/gemini';
import { createMessage } from '$lib/server/db';
import { createErrorResponse, validateChatRequest } from '$lib/server/validation';
import { GoogleGenerativeAI } from '@google/generative-ai';
import OpenAI from 'openai';
import type {
  ChatCompletionMessageParam,
  ChatCompletionTool
} from 'openai/resources/chat/completions';

interface RequestEvent {
  request: Request;
  params: Record<string, string>;
  url: URL;
  getClientAddress: () => string;
  cookies: {
    get: (name: string) => string | undefined;
    set: (name: string, value: string, options?: any) => void;
    delete: (name: string, options?: any) => void;
    getAll: () => { name: string; value: string }[];
  };
  locals: Record<string, any>;
  platform: Record<string, any>;
  route: {
    id: string | null;
  };
}

interface UIPart {
  type: string;
  text?: string;
  toolName?: string;
  result?: unknown;
}
interface UIMessage {
  id?: string;
  role: string;
  content?: string;
  parts?: UIPart[];
}

const MAX_DIAGRAM_LENGTH = 20000;

// Centralized timeout configuration (in milliseconds)
// These should be aligned with client-side timeouts in Chat.svelte
const TIMEOUT_CONFIG = {
  OPENAI_API: 5 * 60 * 1000, // 5 minutes - OpenAI API timeout
  OPENROUTER_API: 5 * 60 * 1000, // 5 minutes - OpenRouter API timeout
  STREAM_TIMEOUT: 10 * 60 * 1000, // 10 minutes - Overall stream timeout (allows for continuation rounds)
  CLIENT_REQUEST: 3 * 60 * 1000 // 3 minutes - Should match Chat.svelte activeTimeoutId (180000ms)
} as const;

// Safe JSON parsing helper with automatic fixing of common issues
function safeJsonParse(
  jsonString: string,
  isDev: boolean = false
): { success: boolean; data: any; error?: string } {
  if (!jsonString || typeof jsonString !== 'string') {
    return { success: false, data: null, error: 'Invalid input: not a string' };
  }

  // First, try direct parsing
  try {
    return { success: true, data: JSON.parse(jsonString) };
  } catch (initialError) {
    if (isDev) console.log('Initial JSON parse failed, attempting fixes...');
  }

  // Try to fix common JSON issues
  let fixedArgs = jsonString
    .trim()
    .replace(/,\s*}$/g, '}')
    .replace(/,\s*]/g, ']')
    .replace(/&quot;/g, '"')
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>');

  // Handle concatenated JSON objects
  if (fixedArgs.includes('}{')) {
    const parts = fixedArgs.split('}{');
    for (let i = 0; i < parts.length; i++) {
      let candidatePart = parts[i];
      if (!candidatePart.startsWith('{')) candidatePart = '{' + candidatePart;
      if (!candidatePart.endsWith('}')) candidatePart = candidatePart + '}';
      try {
        const parsed = JSON.parse(candidatePart);
        if (isDev) console.log(`Found valid JSON in part ${i + 1}`);
        return { success: true, data: parsed };
      } catch (e) {
        // Continue to next part
      }
    }
  }

  // Try to extract JSON object using brace matching
  const firstBrace = fixedArgs.indexOf('{');
  if (firstBrace !== -1) {
    let braceCount = 0;
    for (let i = firstBrace; i < fixedArgs.length; i++) {
      if (fixedArgs[i] === '{') braceCount++;
      else if (fixedArgs[i] === '}') {
        braceCount--;
        if (braceCount === 0) {
          const jsonCandidate = fixedArgs.substring(firstBrace, i + 1);
          try {
            const parsed = JSON.parse(jsonCandidate);
            if (isDev) console.log('Successfully extracted JSON from string');
            return { success: true, data: parsed };
          } catch (e) {
            break;
          }
        }
      }
    }
  }

  // Final attempt with the fixed string
  try {
    return { success: true, data: JSON.parse(fixedArgs) };
  } catch (finalError) {
    return {
      success: false,
      data: null,
      error: finalError instanceof Error ? finalError.message : 'Unknown parse error'
    };
  }
}

// Initialize OpenAI client
const openai = new OpenAI({
  apiKey: OPENAI_API_KEY ?? '',
  timeout: TIMEOUT_CONFIG.OPENAI_API
});

// Initialize OpenRouter client lazily (will be created in POST handler)
let openrouter: OpenAI | null = null;

// Initialize Gemini client lazily (will be created in POST handler)
let gemini: GoogleGenerativeAI | null = null;

// Helper function to determine which client to use based on model
function getAIClient(model: string, isDev: boolean = false) {
  if (isDev) console.log(`getAIClient called with model: ${model}`);

  // Gemini models start with 'gemini-'
  if (isGeminiModel(model)) {
    if (isDev) console.log('Model detected as Gemini');
    if (!gemini) {
      if (isDev) console.error('Gemini client not initialized. Please check your GEMINI_API_KEY.');
      throw new Error('Gemini client not initialized. Please check your GEMINI_API_KEY.');
    }
    if (isDev) console.log('Returning Gemini client');
    return { provider: 'gemini', client: gemini };
  }
  // OpenRouter models typically contain slashes (e.g., "anthropic/claude-3-sonnet")
  if (model.includes('/') && openrouter) {
    if (isDev) console.log('Model detected as OpenRouter');
    return { provider: 'openrouter', client: openrouter };
  }
  if (isDev) console.log('Defaulting to OpenAI');
  return { provider: 'openai', client: openai };
}

// Helper function to handle Gemini streaming
async function handleGeminiStream(
  geminiClient: GoogleGenerativeAI,
  model: string,
  systemPrompt: string,
  userText: string,
  tools: ChatCompletionTool[],
  mode: string,
  sendEvent: (event: string, data: any) => Uint8Array,
  safeEnqueue: (event: string, data: any) => void,
  controller: ReadableStreamDefaultController,
  isDev: boolean
): Promise<Response> {
  try {
    if (isDev) console.log('handleGeminiStream called with model:', model);

    // Get Gemini model
    const geminiModel = geminiClient.getGenerativeModel({ model });
    if (isDev) console.log('Gemini model created successfully');

    // Convert tools to Gemini format
    const geminiTools =
      tools.length > 0 && mode !== 'plan' ? convertValidToolsToGemini(tools) : undefined;
    if (isDev) console.log('Gemini tools converted:', geminiTools ? 'yes' : 'no');

    // Prepare messages
    const messages = [{ role: 'user' as const, content: `${systemPrompt}\n\n${userText}` }];
    if (isDev) console.log('Messages prepared, length:', messages[0].content.length);

    if (isDev) console.log('Starting Gemini streaming...');

    // Stream response
    const stream = geminiStreamResponse(geminiModel, messages, geminiTools ? [geminiTools] : []);
    if (isDev) console.log('Stream created');

    let fullContent = '';
    let functionCall: any = null;
    let eventCount = 0;

    for await (const event of stream) {
      eventCount++;
      if (isDev) console.log(`Gemini event ${eventCount}:`, event.type);

      switch (event.type) {
        case 'text':
          if (event.content) {
            fullContent += event.content;
            safeEnqueue('text', { content: event.content });
            if (isDev) console.log('Text event:', event.content.substring(0, 50) + '...');
          }
          break;
        case 'function_call':
          functionCall = event.functionCall;
          if (functionCall) {
            if (isDev) console.log('Function call:', functionCall.name);
            // Convert to OpenAI format for compatibility
            const openaiToolCall = convertGeminiFunctionCallToOpenAI({
              name: functionCall.name,
              args: JSON.parse(functionCall.arguments || '{}')
            });
            safeEnqueue('tool_call', { tool_call: openaiToolCall });
          }
          break;
        case 'error':
          if (isDev) console.error('Gemini streaming error:', event.error);
          safeEnqueue('error', { message: event.error });
          safeEnqueue('done', {});
          try {
            controller.close();
          } catch (closeError) {
            if (isDev) console.error('Error closing controller:', closeError);
          }
          return new Response(JSON.stringify({ error: 'Gemini API Error', message: event.error }), {
            status: 500,
            headers: { 'Content-Type': 'application/json' }
          });
        case 'done':
          if (isDev) console.log('Gemini stream done');
          break;
      }
    }

    if (isDev)
      console.log(
        `Total events processed: ${eventCount}, Full content length: ${fullContent.length}`
      );

    // Send done event safely
    safeEnqueue('done', {});
    try {
      controller.close();
    } catch (closeError) {
      if (isDev) console.error('Error closing controller:', closeError);
    }

    return new Response('Gemini stream completed', { status: 200 });
  } catch (error) {
    const errorMessage = error instanceof Error ? error.message : 'Unknown error';
    if (isDev) console.error('Gemini stream error:', error);
    return new Response(JSON.stringify({ error: 'Gemini API Error', message: errorMessage }), {
      status: 500,
      headers: { 'Content-Type': 'application/json' }
    });
  }
}

// Helper function to validate Mermaid diagram syntax
function validateMermaidDiagram(diagramCode: string) {
  const validationErrors: Array<{
    line: number;
    column?: number;
    message: string;
    severity: 'error' | 'warning' | 'info';
    suggestion?: string;
    code?: string;
  }> = [];

  const lines = diagramCode.split('\n');

  // Validate diagram syntax
  for (let lineNum = 0; lineNum < lines.length; lineNum++) {
    const line = lines[lineNum];
    const trimmedLine = line.trim();

    if (!trimmedLine || trimmedLine.startsWith('%%')) continue;

    // Check for unclosed brackets
    const openBrackets = (trimmedLine.match(/[\[\(\{]/g) || []).length;
    const closeBrackets = (trimmedLine.match(/[\]\)\}]/g) || []).length;
    if (openBrackets !== closeBrackets) {
      validationErrors.push({
        line: lineNum + 1,
        message: 'Unclosed bracket detected',
        severity: 'error',
        suggestion: 'Add a closing bracket',
        code: trimmedLine.substring(0, 50)
      });
    }

    // Check for unclosed quotes
    const quotes = (trimmedLine.match(/"/g) || []).length;
    if (quotes % 2 !== 0) {
      validationErrors.push({
        line: lineNum + 1,
        message: 'Unclosed quote detected',
        severity: 'error',
        suggestion: 'Add a closing quote',
        code: trimmedLine.substring(0, 50)
      });
    }

    // Check for invalid arrow syntax
    if (trimmedLine.includes('->') && !trimmedLine.includes('|')) {
      const arrowMatch = trimmedLine.match(/\s*->\s*/);
      if (arrowMatch) {
        validationErrors.push({
          line: lineNum + 1,
          message: 'Invalid arrow syntax',
          severity: 'warning',
          suggestion: 'Use proper arrow syntax like A-->B',
          code: trimmedLine.substring(0, 50)
        });
      }
    }

    // Check for empty node labels
    if (trimmedLine.match(/\[\s*\]/) || trimmedLine.match(/\(\s*\)/)) {
      validationErrors.push({
        line: lineNum + 1,
        message: 'Empty node label',
        severity: 'warning',
        suggestion: 'Add a label inside the brackets',
        code: trimmedLine.substring(0, 50)
      });
    }
  }

  // Check for missing diagram type
  const hasValidType = lines.some(
    (line) =>
      line.trim().startsWith('flowchart') ||
      line.trim().startsWith('graph') ||
      line.trim().startsWith('sequenceDiagram') ||
      line.trim().startsWith('classDiagram') ||
      line.trim().startsWith('stateDiagram') ||
      line.trim().startsWith('erDiagram') ||
      line.trim().startsWith('gantt') ||
      line.trim().startsWith('pie') ||
      line.trim().startsWith('journey') ||
      line.trim().startsWith('mindmap') ||
      line.trim().startsWith('timeline')
  );

  if (!hasValidType && diagramCode.trim().length > 0) {
    validationErrors.push({
      line: 1,
      message: 'Missing or invalid diagram type declaration',
      severity: 'error',
      suggestion: 'Add a diagram type like "flowchart TD" at the beginning'
    });
  }

  return validationErrors;
}

