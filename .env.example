# Auth Configuration
MAGNOVA_AUTH_URL=https://auth.magnova.ai
COOKIE_SECRET=
ANTHROPIC_API_KEY=

# Dev: bypass login entirely. Set to 'true' (auto-login as first user) or an email address.
# With `pnpm dev`, localhost / 127.0.0.1 already auto-bypass like DEV_BYPASS_AUTH=true.
# Use DEV_BYPASS_AUTH when using another host (e.g. LAN IP with server.host).
# DEV_BYPASS_AUTH=true

# Database Configuration (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AI Chat API Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# OpenRouter API Configuration
OPENROUTER_API_KEY=

# Gemini API Configuration
GEMINI_API_KEY=

# Domain Configuration
MERMAID_DOMAIN=

# Chat Configuration
CHAT_MAX_CONVERSATIONS_PER_USER=10
CHAT_MAX_MESSAGES_PER_CONVERSATION=100
CHAT_CLEANUP_DAYS=30

# Admin Configuration
ADMIN_SECRET_KEY=your-admin-secret-key
# Emails that get admin UI/API access when DB role is still `user` (comma-separated).
# Prefer ADMIN_EMAIL_OVERRIDES; ADMIN_ALLOWED_EMAILS is accepted as an alias.
ADMIN_EMAIL_OVERRIDES=admin@example.com,user@example.com

# Cache Configuration
CACHE_MAX_ENTRIES=10000
CACHE_DEFAULT_TTL_SECONDS=3600

# State Management
STATE_CLEANUP_INTERVAL_HOURS=1
STATE_RETENTION_DAYS=7
