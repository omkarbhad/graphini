# Auth Configuration
MAGNOVA_AUTH_URL=https://auth.magnova.ai
COOKIE_SECRET=
ANTHROPIC_API_KEY=

# Database Configuration (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AI Chat API Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# OpenRouter API Configuration
OPENROUTER_API_KEY=

# Gemini API Configuration
GEMINI_API_KEY=

# Domain Configuration
MERMAID_DOMAIN=

# Chat Configuration
CHAT_MAX_CONVERSATIONS_PER_USER=10
CHAT_MAX_MESSAGES_PER_CONVERSATION=100
CHAT_CLEANUP_DAYS=30

# Admin Configuration
ADMIN_SECRET_KEY=your-admin-secret-key
ADMIN_ALLOWED_EMAILS=admin@example.com,user@example.com

# Cache Configuration
CACHE_MAX_ENTRIES=10000
CACHE_DEFAULT_TTL_SECONDS=3600

# State Management
STATE_CLEANUP_INTERVAL_HOURS=1
STATE_RETENTION_DAYS=7
