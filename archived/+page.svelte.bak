<script lang="ts">
  import { PanZoomState } from '$/features/diagram/panZoom';
  import type { EditorMode, Tab } from '$/types';
  import {
    inputStateStore,
    setLayout,
    stateStore,
    updateCodeStore,
    type LayoutOption
  } from '$/util/state';
  import { logEvent } from '$/util/stats';
  import { initHandler } from '$/util/util';
  import AuthModal from '$lib/components/AuthModal.svelte';
  import ColorPanel from '$lib/components/canvas/ColorPanel.svelte';
  import IconPanel from '$lib/components/canvas/IconPanel.svelte';
  import Editor from '$lib/components/editor/Editor.svelte';
  import { View } from '$lib/components/layout';
  import RefillGemsModal from '$lib/components/RefillGemsModal.svelte';
  import SettingsModal from '$lib/components/SettingsModal.svelte';
  import PrimarySidebar from '$lib/components/sidebars/PrimarySidebar.svelte';
  import { Button } from '$lib/components/ui/button';
  import * as DropdownMenu from '$lib/components/ui/dropdown-menu';
  import Chat from '$lib/features/chat/components/Chat.simple.svelte';
  import { authStore } from '$lib/stores/auth.svelte';
  import { autosaveStore } from '$lib/stores/autosave';
  import { conversationsStore } from '$lib/stores/conversations.svelte';
  import { fileSystemStore, type UserFile } from '$lib/stores/fileSystem';
  import {
    ArrowLeftRight,
    Download,
    Expand,
    FileCode2,
    Gem,
    Grid3x3,
    Hand,
    Image as ImageIcon,
    Layers,
    LayoutGrid,
    LogOut,
    Moon,
    MousePointer2,
    Palette,
    Pencil,
    Redo,
    RotateCcw,
    Square,
    Sun,
    Undo,
    UserCircle,
    ZoomIn,
    ZoomOut
  } from 'lucide-svelte';
  import { mode, setMode } from 'mode-watcher';
  import { onMount } from 'svelte';
  import { get } from 'svelte/store';
  import RoughIcon from '~icons/material-symbols/draw-outline-rounded';
  import GearIcon from '~icons/material-symbols/settings-outline-rounded';

  const panZoomState = new PanZoomState();

  // Helper function to standardize diagram type names
  function standardizeDiagramType(type: string): string {
    const typeMap: Record<string, string> = {
      flowchart: 'flowchart',
      'flow-chart': 'flowchart',
      sequence: 'sequenceDiagram',
      'sequence-diagram': 'sequenceDiagram',
      class: 'classDiagram',
      'class-diagram': 'classDiagram',
      state: 'stateDiagram',
      'state-diagram': 'stateDiagram',
      er: 'erDiagram',
      'entity-relationship': 'erDiagram',
      gantt: 'gantt',
      pie: 'pie',
      journey: 'journey',
      'user-journey': 'journey',
      mindmap: 'mindmap',
      timeline: 'timeline',
      kanban: 'kanban',
      gitgraph: 'gitGraph',
      'git-graph': 'gitGraph',
      quadrant: 'quadrantChart',
      'quadrant-chart': 'quadrantChart',
      xy: 'xyChart',
      'xy-chart': 'xyChart',
      zenuml: 'zenuml',
      c4: 'c4',
      block: 'block',
      sankey: 'sankey',
      packet: 'packet',
      requirement: 'requirement',
      treemap: 'treemap'
    };
    return typeMap[type] || type;
  }

  // Documentation configuration
  const docURLBase = 'https://mermaid.js.org';
  const docMap = {
    architecture: { code: '/syntax/architecture.html' },
    block: { code: '/syntax/block.html' },
    c4: { code: '/syntax/c4.html' },
    class: { code: '/syntax/classDiagram.html', config: '/syntax/classDiagram.html#configuration' },
    er: {
      code: '/syntax/entityRelationshipDiagram.html',
      config: '/syntax/entityRelationshipDiagram.html#styling'
    },
    flowchart: { code: '/syntax/flowchart.html', config: '/syntax/flowchart.html#configuration' },
    gantt: { code: '/syntax/gantt.html', config: '/syntax/gantt.html#configuration' },
    gitGraph: {
      code: '/syntax/gitgraph.html',
      config: '/syntax/gitgraph.html#gitgraph-specific-configuration-options'
    },
    journey: { code: '/syntax/userJourney.html' },
    kanban: { code: '/syntax/kanban.html', config: '/syntax/kanban.html#configuration-options' },
    mindmap: { code: '/syntax/mindmap.html' },
    packet: {
      code: '/syntax/packet.html',
      config: '/config/schema-docs/config-defs-packet-diagram-config.html'
    },
    pie: { code: '/syntax/pie.html', config: '/syntax/pie.html#configuration' },
    quadrantChart: {
      code: '/syntax/quadrantChart.html',
      config: '/syntax/quadrantChart.html#chart-configurations'
    },
    requirement: { code: '/syntax/requirementDiagram.html' },
    sankey: { code: '/syntax/sankey.html', config: '/syntax/sankey.html#configuration' },
    sequence: {
      code: '/syntax/sequenceDiagram.html',
      config: '/syntax/sequenceDiagram.html#configuration'
    },
    stateDiagram: { code: '/syntax/stateDiagram.html' },
    timeline: { code: '/syntax/timeline.html', config: '/syntax/timeline.html#themes' },
    treemap: { code: '/syntax/treemap.html', config: '/syntax/treemap.html#configuration-options' },
    xychart: { code: '/syntax/xyChart.html', config: '/syntax/xyChart.html#chart-configurations' },
    zenuml: { code: '/syntax/zenuml.html' }
  };

  const tabSelectHandler = (tab: Tab) => {
    const editorMode: EditorMode =
      tab.id === 'code' ? 'code' : tab.id === 'chat' ? 'chat' : 'config';
    updateCodeStore({ editorMode });
  };

  const editorTabs: Tab[] = [
    { icon: CodeIcon, id: 'code', title: 'Code' },
    { icon: GearIcon, id: 'config', title: 'Config' }
  ];

  let width = $state(0);
  let isMobile = $derived(width < 640);

  // ── UI State Persistence ──
  function loadUIState<T>(key: string, fallback: T): T {
    try {
      const v = localStorage.getItem(`graphini_ui_${key}`);
      if (v !== null) return JSON.parse(v);
    } catch {}
    return fallback;
  }
  function saveUIState(key: string, value: any) {
    try {
      localStorage.setItem(`graphini_ui_${key}`, JSON.stringify(value));
    } catch {}
  }

  // Panel icon map for toggle buttons
  const panelIcons: Record<PanelId, typeof FolderOpen> = {
    files: FolderOpen,
    canvas: Layers,
    document: FileText,
    code: Code2,
    chat: MessageSquare
  };

  // Settings modal state
  let isSettingsModalOpen = $state(false);
  let isAuthModalOpen = $state(false);
  let isRefillGemsOpen = $state(false);
  let isShortcutsModalOpen = $state(false);

  // Canvas panel states
  let isColorPanelOpen = $state(false);
  let isIconPanelOpen = $state(false);

  // Panel resize helper
  function handlePanelResize(panelId: PanelId, delta: number) {
    const panels = get(panelStore);
    const currentWidth = panels[panelId].width;
    panelStore.setWidth(panelId, currentWidth + delta);
  }

  // Current state for toolbar
  let currentState: any = $state(undefined);
  let currentLayout: LayoutOption = $state('dagre');
  let activeTool = $state<'select' | 'pan' | 'draw'>(loadUIState('activeTool', 'select'));
  let isGridVisible = $state(loadUIState('gridVisible', false));
  let isRoughMode = $state(loadUIState('roughMode', false));
  let zoomLevel = $state(100);
  let isViewRendering = $state(false);
  let viewRenderError = $state('');
  let selectedElementLabel = $state<string | null>(null);
  let selectedElementNodeName = $state<string | null>(null);
  let selectedElementType = $state<'node' | 'edge' | null>(null);

  // Persist UI state changes — batched into a single debounced effect
  let uiSaveTimeout: ReturnType<typeof setTimeout> | null = null;
  $effect(() => {
    // Access all reactive values to track them
    const _state = {
      pv: isPrimarySidebarVisible,
      sv: isSecondarySidebarVisible,
      pp: primarySidebarPosition,
      sp: secondarySidebarPosition,
      pc: primarySidebarContent,
      sc: secondarySidebarContent,
      pw: primarySidebarWidth,
      sw: secondarySidebarWidth,
      at: activeTool,
      gv: isGridVisible,
      rm: isRoughMode
    };
    if (uiSaveTimeout) clearTimeout(uiSaveTimeout);
    uiSaveTimeout = setTimeout(() => {
      saveUIState('primaryVisible', _state.pv);
      saveUIState('secondaryVisible', _state.sv);
      saveUIState('primaryPos', _state.pp);
      saveUIState('secondaryPos', _state.sp);
      saveUIState('primaryContent', _state.pc);
      saveUIState('secondaryContent', _state.sc);
      saveUIState('primaryWidth', _state.pw);
      saveUIState('secondaryWidth', _state.sw);
      saveUIState('activeTool', _state.at);
      saveUIState('gridVisible', _state.gv);
      saveUIState('roughMode', _state.rm);
    }, 300);
  });

  // Documentation URL derived from current diagram type
  const documentationURL = $derived.by(() => {
    const { diagramType, editorMode } = currentState || {};
    if (!diagramType) {
      return { key: '', url: docURLBase };
    }
    const key = standardizeDiagramType(diagramType);
    const docConfig = docMap[key] || { code: '' };
    const url = docURLBase + (docConfig[editorMode] || docConfig.code || '');
    return { key, url };
  });

  const unsubscribe = (inputStateStore as any).subscribe((state: any) => {
    currentState = state;
    // Update current layout from mermaid config
    try {
      const config = JSON.parse(state.mermaid);
      const layout = config.layout || 'dagre';
      if (layout === 'elk') {
        currentLayout = layout;
      } else {
        currentLayout = 'dagre';
      }
    } catch {
      currentLayout = 'dagre';
    }
  });

  const setupPanZoomObserver = () => {
    panZoomState.onPanZoomChange = (pan, zoom) => {
      updateCodeStore({ pan, zoom });
      zoomLevel = Math.round(zoom * 100);
      logEvent('panZoom');
    };
  };

  // Apply edge styling in mermaid code via linkStyle directive
  function applyEdgeStyle(edgeIndex: number, color: string) {
    const state = get(inputStateStore);
    if (!state?.code) return;
    let code = state.code;

    // Remove any existing linkStyle for this edge index
    const linkStyleRegex = new RegExp(`\\n\\s*linkStyle\\s+${edgeIndex}\\s+[^\\n]*`, 'g');
    code = code.replace(linkStyleRegex, '');

    // Append linkStyle directive at the end
    const linkStyle = `\n    linkStyle ${edgeIndex} stroke:${color},stroke-width:3px`;
    code = code.trimEnd() + linkStyle + '\n';

    updateCodeStore({ code });
  }

  onMount(() => {
    setupPanZoomObserver();

    // Initialize auth (check session)
    authStore.init();

    // Initialize autosave
    autosaveStore.init();

    // Restore current file from localStorage and load its content into editor
    const savedFile = fileSystemStore.loadCurrentFile();
    if (savedFile) {
      fileSystemStore.setCurrentFile(savedFile);
      autosaveStore.setCurrentFile(savedFile);
      if (savedFile.content) {
        updateCodeStore({ code: savedFile.content });
      }
      autoFileCreated = true;
    }
    fileSystemStore.loadUserFiles();

    const setup = async () => {
      await initHandler();
      window.addEventListener('appinstalled', () => {
        logEvent('pwaInstalled', { isMobile });
      });
    };
    setup();

    // Add global mouse event listeners for resize
    window.addEventListener('mousemove', handleMouseMove);
    window.addEventListener('mouseup', handleMouseUp);

    // Listen for canvas selection events
    const handleNodeSelected = (e: CustomEvent) => {
      const rawId = e.detail.nodeId || '';
      // Clean node name from SVG ID (strip flowchart- prefix and -N suffix)
      const cleanName =
        rawId
          .replace(/^flowchart-/, '')
          .replace(/^stateDiagram-/, '')
          .replace(/^classDiagram-/, '')
          .replace(/-\d+$/, '') || null;
      selectedElementNodeName = cleanName;
      selectedElementLabel = e.detail.label || 'Node';
      selectedElementType = 'node';
    };
    const handleEdgeSelected = (e: CustomEvent) => {
      selectedElementLabel = e.detail.label || 'Edge';
      selectedElementType = 'edge';
    };
    const handleSelectionCleared = () => {
      selectedElementLabel = null;
      selectedElementNodeName = null;
      selectedElementType = null;
    };
    window.addEventListener('node-selected', handleNodeSelected as EventListener);
    window.addEventListener('edge-selected', handleEdgeSelected as EventListener);
    window.addEventListener('selection-cleared', handleSelectionCleared as EventListener);

    // Listen for conversation creation from Chat component
    const handleConversationCreated = async (e: CustomEvent) => {
      if (authStore.isLoggedIn) {
        const title = e.detail?.title || 'New Chat';
        await conversationsStore.create(title);
      }
    };
    window.addEventListener('conversation-created', handleConversationCreated as EventListener);

    // Listen for auth modal event from chat
    const handleOpenAuthModal = () => {
      isAuthModalOpen = true;
    };
    window.addEventListener('open-auth-modal', handleOpenAuthModal);

    // Listen for refill gems event from chat
    const handleOpenRefillGems = () => {
      isRefillGemsOpen = true;
    };
    window.addEventListener('open-refill-gems', handleOpenRefillGems);

    // Auto-create file with random name if none exists on initial render
    if (!autoFileCreated) {
      const randomName = `Diagram-${Date.now().toString(36).slice(-4).toUpperCase()}.mmd`;
      fileSystemStore.createFile(randomName).then((file) => {
        if (file) {
          autosaveStore.setCurrentFile(file);
          autoFileCreated = true;
        }
      });
    }

    // Add keyboard shortcuts
    const handleKeyDown = (e: KeyboardEvent) => {
      // Only trigger shortcuts when not typing in input fields
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) {
        return;
      }

      // Ctrl/Cmd + Z: Undo
      if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
        e.preventDefault();
        handleUndo();
      }

      // Ctrl/Cmd + Shift + Z or Ctrl/Cmd + Y: Redo
      if ((e.ctrlKey || e.metaKey) && (e.key === 'y' || (e.key === 'z' && e.shiftKey))) {
        e.preventDefault();
        handleRedo();
      }

      // Delete or Backspace: Delete selected
      if (e.key === 'Delete' || e.key === 'Backspace') {
        e.preventDefault();
        handleDelete();
      }

      // Ctrl/Cmd + S: Export
      if ((e.ctrlKey || e.metaKey) && e.key === 's') {
        e.preventDefault();
        handleExport();
      }

      // Ctrl/Cmd + O: Import
      if ((e.ctrlKey || e.metaKey) && e.key === 'o') {
        e.preventDefault();
        handleImport();
      }

      // V: Select tool
      if (e.key === 'v' && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
        handleToolSelect('select');
      }

      // P: Pan tool
      if (e.key === 'p' && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
        handleToolSelect('pan');
      }

      // D: Draw tool
      if (e.key === 'd' && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
        handleToolSelect('draw');
      }

      // G: Toggle grid
      if (e.key === 'g' && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
        toggleGrid();
      }

      // R: Toggle rough mode
      if (e.key === 'r' && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
        toggleRoughMode();
      }

      // Ctrl/Cmd + +: Zoom in
      if ((e.ctrlKey || e.metaKey) && (e.key === '+' || e.key === '=')) {
        e.preventDefault();
        panZoomState.zoomIn();
        zoomLevel = Math.min(400, zoomLevel + 10);
      }

      // Ctrl/Cmd + -: Zoom out
      if ((e.ctrlKey || e.metaKey) && e.key === '-') {
        e.preventDefault();
        panZoomState.zoomOut();
        zoomLevel = Math.max(25, zoomLevel - 10);
      }

      // Ctrl/Cmd + 0: Reset zoom
      if ((e.ctrlKey || e.metaKey) && e.key === '0') {
        e.preventDefault();
        panZoomState.reset();
        zoomLevel = 100;
      }

      // Ctrl/Cmd + B: Toggle primary sidebar
      if ((e.ctrlKey || e.metaKey) && e.key === 'b') {
        e.preventDefault();
        isPrimarySidebarVisible = !isPrimarySidebarVisible;
      }

      // Ctrl/Cmd + Shift + B: Toggle secondary sidebar
      if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'B') {
        e.preventDefault();
        isSecondarySidebarVisible = !isSecondarySidebarVisible;
      }

      // Ctrl/Cmd + Shift + S: Swap sidebar content and positions
      if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'S') {
        e.preventDefault();
        swapSidebarContent();
      }

      // ?: Show keyboard shortcuts
      if (e.key === '?' && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
        isShortcutsModalOpen = !isShortcutsModalOpen;
      }
    };

    window.addEventListener('keydown', handleKeyDown);

    return () => {
      unsubscribe();
      window.removeEventListener('mousemove', handleMouseMove);
      window.removeEventListener('mouseup', handleMouseUp);
      window.removeEventListener('keydown', handleKeyDown);
      window.removeEventListener('node-selected', handleNodeSelected as EventListener);
      window.removeEventListener('edge-selected', handleEdgeSelected as EventListener);
      window.removeEventListener('selection-cleared', handleSelectionCleared as EventListener);
      window.removeEventListener(
        'conversation-created',
        handleConversationCreated as EventListener
      );
      window.removeEventListener('open-auth-modal', handleOpenAuthModal);
      window.removeEventListener('open-refill-gems', handleOpenRefillGems);
    };
  });

  let chatComponent = $state<Chat | undefined>(undefined);

  const toggleTheme = () => {
    setMode($mode === 'dark' ? 'light' : 'dark');
    // Dispatch theme change event
    window.dispatchEvent(
      new CustomEvent('theme-changed', {
        detail: { theme: $mode === 'dark' ? 'light' : 'dark' }
      })
    );
  };

  const handleToolSelect = (tool: 'select' | 'pan' | 'draw') => {
    activeTool = tool;
    // Dispatch event to notify canvas
    window.dispatchEvent(new CustomEvent('tool-changed', { detail: { tool } }));
  };

  const handleUndo = () => {
    window.dispatchEvent(new CustomEvent('undo'));
  };

  const handleRedo = () => {
    window.dispatchEvent(new CustomEvent('redo'));
  };

  const handleExport = () => {
    // Export as SVG — clone to strip selection artifacts
    const svgElement = document.querySelector('#graph-div');
    if (svgElement) {
      const clone = svgElement.cloneNode(true) as Element;
      // Remove selection rectangles and classes added by the editor
      clone.querySelectorAll('.graphini-selection-rect').forEach((el) => el.remove());
      clone
        .querySelectorAll('.graphini-selected')
        .forEach((el) => el.classList.remove('graphini-selected'));
      const svgData = new XMLSerializer().serializeToString(clone);
      const blob = new Blob([svgData], { type: 'image/svg+xml' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      // Use current file name if available
      const currentFile = get(fileSystemStore).currentFile;
      const baseName = currentFile?.name?.replace(/\.[^.]+$/, '') || 'diagram';
      a.download = `${baseName}.svg`;
      a.click();
      URL.revokeObjectURL(url);
    }
  };

  const handleImport = () => {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.mmd,.mermaid,.json';
    input.onchange = (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (e) => {
          const content = e.target?.result as string;
          updateCodeStore({ code: content });
        };
        reader.readAsText(file);
      }
    };
    input.click();
  };

  const handleDelete = () => {
    window.dispatchEvent(new CustomEvent('delete-selected'));
  };

  const handleLayoutChange = (layout: LayoutOption) => {
    currentLayout = layout;
    setLayout(layout);
  };

  const toggleGrid = () => {
    isGridVisible = !isGridVisible;
    window.dispatchEvent(new CustomEvent('grid-toggle', { detail: { visible: isGridVisible } }));
  };

  const toggleRoughMode = () => {
    isRoughMode = !isRoughMode;
    window.dispatchEvent(
      new CustomEvent('rough-mode-toggle', { detail: { enabled: isRoughMode } })
    );
  };

  const swapSidebarContent = () => {
    // Swap content
    const temp = primarySidebarContent;
    primarySidebarContent = secondarySidebarContent;
    secondarySidebarContent = temp;

    // Also swap positions (most common UX expectation)
    const tempPos = primarySidebarPosition;
    primarySidebarPosition = secondarySidebarPosition;
    secondarySidebarPosition = tempPos;
  };

  const startResizePrimary = (e: MouseEvent) => {
    isResizingPrimary = true;
    resizeStartX = e.clientX;
    resizeStartWidth = primarySidebarWidth;
    e.preventDefault();
  };

  const startResizePrimaryFromKeyboard = () => {
    // Create a synthetic mouse event for keyboard activation
    const syntheticEvent = new MouseEvent('mousedown', {
      clientX: window.innerWidth / 2, // Use center of screen as fallback
      bubbles: true,
      cancelable: true
    });
    startResizePrimary(syntheticEvent);
  };

  const startResizeSecondary = (e: MouseEvent) => {
    isResizingSecondary = true;
    resizeStartX = e.clientX;
    resizeStartWidth = secondarySidebarWidth;
    e.preventDefault();
  };

  const startResizeSecondaryFromKeyboard = () => {
    // Create a synthetic mouse event for keyboard activation
    const syntheticEvent = new MouseEvent('mousedown', {
      clientX: window.innerWidth / 2, // Use center of screen as fallback
      bubbles: true,
      cancelable: true
    });
    startResizeSecondary(syntheticEvent);
  };

  const handleMouseMove = (e: MouseEvent) => {
    if (isResizingPrimary) {
      // Unified delta calculation
      const delta = e.clientX - resizeStartX;

      // For left sidebar: dragging right → bigger, left → smaller
      // For right sidebar: dragging left → bigger, right → smaller → invert delta
      const signedDelta = primarySidebarPosition === 'left' ? delta : -delta;

      const maxWidth = getResponsiveSidebarWidth(800);
      const minWidth = width < 640 ? 150 : 200;
      const newWidth = Math.max(minWidth, Math.min(maxWidth, resizeStartWidth + signedDelta));
      primarySidebarWidth = newWidth;
    } else if (isResizingSecondary) {
      // Unified delta calculation
      const delta = e.clientX - resizeStartX;

      // For left sidebar: dragging right → bigger, left → smaller
      // For right sidebar: dragging left → bigger, right → smaller → invert delta
      const signedDelta = secondarySidebarPosition === 'left' ? delta : -delta;

      const maxWidth = getResponsiveSidebarWidth(800);
      const minWidth = width < 640 ? 150 : 200;
      const newWidth = Math.max(minWidth, Math.min(maxWidth, resizeStartWidth + signedDelta));
      secondarySidebarWidth = newWidth;
    }
  };

  const handleMouseUp = () => {
    isResizingPrimary = false;
    isResizingSecondary = false;
  };

  const handleClearChat = () => {
    chatComponent?.clearChat();
  };

  const handleNewChat = () => {
    chatComponent?.clearChat();
  };

  const handleSendChatMessage = async (message: string): Promise<boolean> => {
    if (chatComponent) {
      return await chatComponent.sendMessageExternal(message);
    }
    return false;
  };

  // Auto-create file on first code edit if none exists
  let autoFileCreated = false;
  async function ensureFileExists() {
    if (autoFileCreated) return;
    const fsState = $fileSystemStore;
    if (!fsState.currentFile) {
      autoFileCreated = true;
      const editorState = get(inputStateStore);
      const file = await fileSystemStore.createFile('Untitled.mmd');
      // Persist any code already in the editor to the new file
      if (editorState.code) {
        await fileSystemStore.updateFile(file.id, editorState.code);
      }
      autosaveStore.setCurrentFile(file);
      autosaveStore.markChanged();
    }
  }

  // Navbar inline rename state
  let isRenamingInNavbar = $state(false);
  let navbarRenameValue = $state('');

  // Sync document.title with current file name
  $effect(() => {
    const name = $fileSystemStore.currentFile?.name || 'Untitled.mmd';
    document.title = `${name.replace('.mmd', '')} — Graphini`;
  });

  function startNavbarRename() {
    const name = $fileSystemStore.currentFile?.name || '';
    navbarRenameValue = name.replace('.mmd', '');
    isRenamingInNavbar = true;
  }

  async function saveNavbarRename() {
    const currentFile = $fileSystemStore.currentFile;
    if (!currentFile || !navbarRenameValue.trim()) {
      isRenamingInNavbar = false;
      return;
    }
    const newName = navbarRenameValue.trim().endsWith('.mmd')
      ? navbarRenameValue.trim()
      : navbarRenameValue.trim() + '.mmd';
    await fileSystemStore.renameFile(currentFile.id, newName);
    isRenamingInNavbar = false;
  }

  const handleFileOpen = async (file: UserFile) => {
    // Save current file content before switching
    const currentFile = $fileSystemStore.currentFile;
    if (currentFile && currentFile.id !== file.id) {
      const state = get(inputStateStore);
      const currentCode = state.code || '';
      if (currentCode || currentFile.content) {
        await fileSystemStore.updateFile(currentFile.id, currentCode);
      }
    }
    // Load the new file's content into the editor and force canvas re-render
    updateCodeStore({ code: file.content || '', updateDiagram: true });
    // Set as current file in the store
    fileSystemStore.setCurrentFile(file);
    // Set up autosave for this file
    autosaveStore.setCurrentFile(file);
    autoFileCreated = true;
  };
</script>

<div class="flex h-screen flex-col overflow-hidden bg-background" bind:clientWidth={width}>
  <!-- Top Header Bar -->
  <header class="glass flex h-12 items-center justify-between px-4">
    <!-- Left: Logo and branding -->
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2.5">
        <img src="/brand/logo.png" alt="Graphini" class="size-7" />
        <span class="text-[15px] font-semibold tracking-tight text-foreground">Graphini</span>
      </div>
      <div class="divider-v mx-1 hidden sm:block"></div>
      <div class="hidden items-center gap-2 sm:flex">
        <FileCode2 class="size-4 text-muted-foreground" />
        {#if isRenamingInNavbar}
          <input
            type="text"
            bind:value={navbarRenameValue}
            class="h-7 w-40 rounded-md border border-border bg-background px-2 text-[13px] text-foreground focus:border-primary focus:ring-1 focus:ring-primary/30 focus:outline-none"
            onkeydown={(e) => {
              if (e.key === 'Enter') saveNavbarRename();
              if (e.key === 'Escape') {
                isRenamingInNavbar = false;
              }
            }}
            onblur={() => saveNavbarRename()}
            autofocus />
        {:else}
          <button
            type="button"
            class="group flex items-center gap-1 rounded-md px-1.5 py-0.5 text-[13px] text-foreground transition-colors hover:bg-muted/60"
            onclick={() => startNavbarRename()}
            title="Click to rename">
            <span class="max-w-[200px] truncate"
              >{$fileSystemStore.currentFile?.name || 'Untitled.mmd'}</span>
            <Pencil
              class="size-3 text-muted-foreground/0 transition-colors group-hover:text-muted-foreground" />
          </button>
        {/if}
      </div>
    </div>

    <!-- Center: Quick actions -->
    <div class="hidden items-center gap-1 md:flex">
      <!-- Center content removed -->
    </div>

    {#if isMobile}
      <div class="flex items-center gap-1">
        <Button
          variant="ghost"
          size="sm"
          class="gap-1.5 text-xs"
          onclick={() => {
            if (isPrimarySidebarVisible) {
              isPrimarySidebarVisible = false;
              isSecondarySidebarVisible = true;
            } else {
              isPrimarySidebarVisible = true;
              isSecondarySidebarVisible = false;
            }
          }}>
          {#if isPrimarySidebarVisible}
            <ChevronRight class="size-4" />
            <span>Chat</span>
          {:else}
            <ChevronLeft class="size-4" />
            <span>Tools</span>
          {/if}
        </Button>
      </div>
    {/if}

    <!-- Right: Actions -->
    <div class="flex items-center gap-1">
      <!-- All Icons Grouped Together -->
      <div class="flex items-center gap-1">
        <Button
          variant="ghost"
          size="icon"
          class="icon-btn size-9 {isPrimarySidebarVisible ? 'active' : ''}"
          title="Toggle Primary Sidebar"
          onclick={() => (isPrimarySidebarVisible = !isPrimarySidebarVisible)}>
          <PanelLeft class="size-4" />
        </Button>
        <Button
          variant="ghost"
          size="icon"
          class="icon-btn size-9 {isSecondarySidebarVisible ? 'active' : ''}"
          title="Toggle Secondary Sidebar"
          onclick={() => (isSecondarySidebarVisible = !isSecondarySidebarVisible)}>
          <PanelRight class="size-4" />
        </Button>
        <Button
          variant="ghost"
          size="icon"
          class="icon-btn size-9"
          title="Swap Panels"
          onclick={swapSidebarContent}>
          <ArrowLeftRight class="size-4" />
        </Button>
        <Button
          variant="ghost"
          size="icon"
          class="icon-btn size-9"
          title="Toggle theme"
          onclick={toggleTheme}>
          {#if $mode === 'dark'}
            <Sun class="size-4" />
          {:else}
            <Moon class="size-4" />
          {/if}
        </Button>
        <Button
          variant="ghost"
          size="icon"
          class="icon-btn size-9"
          title="Settings"
          onclick={() => {
            isSettingsModalOpen = true;
          }}>
          <GearIcon class="size-4" />
        </Button>
        <!-- Gems / Credits -->
        <button
          type="button"
          class="icon-btn flex h-8 items-center gap-1.5 rounded-full bg-purple-500/10 px-3 text-purple-600 transition-colors hover:bg-purple-500/20 dark:text-purple-400"
          title={authStore.isLoggedIn
            ? `Gems: ${authStore.credits?.balance ?? 0} — Click to refill`
            : 'Sign in to view gems'}
          onclick={() => {
            if (authStore.isLoggedIn) {
              isRefillGemsOpen = true;
            } else {
              isAuthModalOpen = true;
            }
          }}>
          <Gem class="size-4" />
          <span class="text-[11px] font-semibold tabular-nums">
            {#if authStore.isLoggedIn && authStore.credits}
              {authStore.credits.balance}
            {:else}
              0
            {/if}
          </span>
        </button>

        <!-- User Auth -->
        {#if authStore.isLoggedIn}
          {@const initials = (authStore.user?.display_name || authStore.user?.email || 'U')
            .split(' ')
            .map((w) => w[0])
            .join('')
            .toUpperCase()
            .slice(0, 2)}
          <DropdownMenu.Root>
            <DropdownMenu.Trigger
              class="flex size-8 items-center justify-center rounded-full bg-primary text-[11px] font-semibold text-primary-foreground ring-1 ring-border/50 transition-colors hover:ring-border focus:outline-none">
              {initials}
            </DropdownMenu.Trigger>
            <DropdownMenu.Content align="end" class="w-56">
              <DropdownMenu.Label class="flex flex-col gap-0.5">
                <span class="text-sm font-medium">{authStore.user?.display_name || 'User'}</span>
                <span class="text-xs font-normal text-muted-foreground"
                  >{authStore.user?.email}</span>
              </DropdownMenu.Label>
              <DropdownMenu.Separator />
              <DropdownMenu.Item
                class="gap-2"
                onclick={() => {
                  isRefillGemsOpen = true;
                }}>
                <Gem class="size-4 text-purple-500" />
                <span>Gems: {authStore.credits?.balance ?? 0}</span>
              </DropdownMenu.Item>
              <DropdownMenu.Separator />
              <DropdownMenu.Item
                class="gap-2 text-red-500 focus:text-red-500"
                onclick={() => authStore.logout()}>
                <LogOut class="size-4" />
                <span>Sign out</span>
              </DropdownMenu.Item>
            </DropdownMenu.Content>
          </DropdownMenu.Root>
        {:else}
          <button
            type="button"
            class="flex size-8 items-center justify-center rounded-full bg-muted text-[11px] font-medium text-muted-foreground ring-1 ring-border/50 transition-colors hover:bg-muted/80"
            title="Sign in"
            onclick={() => {
              isAuthModalOpen = true;
            }}>
            <UserCircle class="size-4" />
          </button>
        {/if}
      </div>
    </div>
  </header>

  <!-- Main Content Area -->
  <div
    class="flex flex-1 overflow-hidden {isResizingPrimary || isResizingSecondary
      ? 'cursor-ew-resize'
      : ''}"
    role="main">
    <!-- Primary Sidebar (can be positioned left or right) -->
    {#if isPrimarySidebarVisible}
      {#if primarySidebarPosition === 'left'}
        <div
          class="relative flex-shrink-0 transition-[width] duration-200 ease-out"
          style="width: {primarySidebarWidth}px;">
          {#if primarySidebarContent === 'tools'}
            <PrimarySidebar onFileOpen={handleFileOpen} />
          {:else if primarySidebarContent === 'code'}
            <SecondarySidebar>
              <div class="flex h-full flex-col">
                <div class="flex-1 overflow-hidden">
                  <Editor
                    onUpdate={(code) => {
                      updateCodeStore({ code });
                      ensureFileExists();
                      autosaveStore.markChanged();
                    }}
                    isMobile={width < 768}
                    sendChatMessage={async (message) => {
                      if (chatComponent) {
                        return await chatComponent.sendMessageExternal(message);
                      }
                      return false;
                    }} />
                </div>
              </div>
            </SecondarySidebar>
          {:else if primarySidebarContent === 'chat'}
            <SecondarySidebar
              onNewChat={handleNewChat}
              onClearChat={handleClearChat}
              onSelectConversation={(id) => console.log('Switch to conversation:', id)}
              sendChatMessage={handleSendChatMessage}>
              <div class="flex h-full flex-col">
                <div class="flex-1 overflow-hidden">
                  <Chat bind:this={chatComponent} />
                </div>
              </div>
            </SecondarySidebar>
          {/if}

          <!-- Resize Handle for Primary Sidebar -->
          <!-- svelte-ignore a11y_no_noninteractive_element_interactions -->
          <div
            class="group absolute top-0 right-0 z-10 h-full w-1 cursor-ew-resize bg-transparent transition-colors hover:bg-primary/20 {isResizingPrimary
              ? 'bg-primary/40'
              : ''}"
            role="separator"
            aria-orientation="vertical"
            aria-label="Resize primary sidebar"
            onmousedown={startResizePrimary}>
            <div
              class="absolute top-1/2 right-1/2 translate-x-1/2 -translate-y-1/2 opacity-0 transition-opacity group-hover:opacity-100">
              <div
                class="flex h-12 w-6 items-center justify-center rounded-full bg-black text-white shadow-lg">
                <svg
                  class="h-4 w-4 text-white"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
                </svg>
              </div>
            </div>
          </div>
        </div>
      {/if}
    {/if}

    <!-- Primary Sidebar positioned on right -->
    {#if isPrimarySidebarVisible && primarySidebarPosition === 'right'}
      <div
        class="relative flex-shrink-0 transition-[width] duration-200 ease-out"
        style="width: {primarySidebarWidth}px;">
        {#if primarySidebarContent === 'tools'}
          <PrimarySidebar onFileOpen={handleFileOpen} />
        {:else if primarySidebarContent === 'code'}
          <SecondarySidebar>
            <div class="flex h-full flex-col">
              <div class="flex-1 overflow-hidden">
                <Editor
                  onUpdate={(code) => {
                    updateCodeStore({ code });
                    autosaveStore.markChanged();
                  }}
                  isMobile={width < 768}
                  sendChatMessage={async (message) => {
                    if (chatComponent) {
                      return await chatComponent.sendMessageExternal(message);
                    }
                    return false;
                  }} />
              </div>
            </div>
          </SecondarySidebar>
        {:else if primarySidebarContent === 'chat'}
          <SecondarySidebar
            onNewChat={handleNewChat}
            onClearChat={handleClearChat}
            onSelectConversation={(id) => console.log('Switch to conversation:', id)}
            sendChatMessage={handleSendChatMessage}>
            <div class="flex h-full flex-col">
              <div class="flex-1 overflow-hidden">
                <Chat bind:this={chatComponent} />
              </div>
            </div>
          </SecondarySidebar>
        {/if}

        <!-- Resize Handle for Primary Sidebar (right position) -->
        <!-- svelte-ignore a11y_no_noninteractive_element_interactions -->
        <div
          class="group absolute top-0 left-0 z-10 h-full w-1 cursor-ew-resize bg-transparent transition-colors hover:bg-primary/20 {isResizingPrimary
            ? 'bg-primary/40'
            : ''}"
          role="separator"
          aria-orientation="vertical"
          aria-label="Resize primary sidebar"
          onmousedown={startResizePrimary}>
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 transition-opacity group-hover:opacity-100">
            <div
              class="flex h-12 w-6 items-center justify-center rounded-full bg-black text-white shadow-lg">
              <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
              </svg>
            </div>
          </div>
        </div>
      </div>
    {/if}

    <!-- Center: Canvas Area -->
    <div class="relative flex flex-1 flex-col overflow-hidden">
      <!-- Canvas Toolbar - Improved -->
      <div
        class="glass-card scrollbar-thin scrollbar-thumb-muted scrollbar-track-transparent flex h-10 items-center gap-1 overflow-x-auto rounded-none border-x-0 border-b border-border/30 px-2 sm:gap-1.5 sm:px-3 md:overflow-x-visible">
        <!-- Diagram Type Badge -->
        {#if documentationURL.key}
          <a
            href={documentationURL.url}
            target="_blank"
            rel="noopener noreferrer"
            class="mr-1 flex items-center gap-1.5 rounded-md bg-primary/8 px-2.5 py-1 text-xs font-semibold text-primary transition-colors hover:bg-primary/15"
            title="View {documentationURL.key} docs">
            <FileCode2 class="size-3.5" />
            <span class="hidden capitalize sm:inline">{documentationURL.key}</span>
          </a>
        {/if}

        <div class="divider-v hidden sm:block"></div>

        <!-- Interaction Tools -->
        <div class="toolbar-group flex-shrink-0">
          <Button
            variant="ghost"
            size="icon"
            class="toolbar-btn {activeTool === 'select' ? 'active' : ''}"
            title="Select (V)"
            onclick={() => handleToolSelect('select')}>
            <MousePointer2 class="size-4" />
          </Button>
          <Button
            variant="ghost"
            size="icon"
            class="toolbar-btn {activeTool === 'pan' ? 'active' : ''}"
            title="Pan (H)"
            onclick={() => handleToolSelect('pan')}>
            <Hand class="size-4" />
          </Button>
          <Button
            variant="ghost"
            size="icon"
            class="toolbar-btn {activeTool === 'draw' ? 'active' : ''}"
            title="Draw (D)"
            onclick={() => handleToolSelect('draw')}>
            <Pencil class="size-4" />
          </Button>
        </div>

        <div class="divider-v hidden sm:block"></div>

        <!-- Undo / Redo -->
        <div class="toolbar-group hidden flex-shrink-0 sm:flex">
          <Button
            variant="ghost"
            size="icon"
            class="toolbar-btn"
            title="Undo (Ctrl+Z)"
            onclick={handleUndo}>
            <Undo class="size-4" />
          </Button>
          <Button
            variant="ghost"
            size="icon"
            class="toolbar-btn"
            title="Redo (Ctrl+Y)"
            onclick={handleRedo}>
            <Redo class="size-4" />
          </Button>
        </div>

        <div class="divider-v hidden md:block"></div>

        <!-- Style & View -->
        <div class="toolbar-group flex-shrink-0">
          <Button
            variant="ghost"
            size="icon"
            class="toolbar-btn {isColorPanelOpen ? 'active' : ''}"
            title="Colors (C)"
            onclick={() => {
              isColorPanelOpen = !isColorPanelOpen;
              isIconPanelOpen = false;
            }}>
            <Palette class="size-4" />
          </Button>
          <Button
            variant="ghost"
            size="icon"
            class="toolbar-btn {isIconPanelOpen ? 'active' : ''}"
            title="Icons (I)"
            onclick={() => {
              isIconPanelOpen = !isIconPanelOpen;
              isColorPanelOpen = false;
            }}>
            <ImageIcon class="size-4" />
          </Button>
          <Button
            variant="ghost"
            size="icon"
            class="toolbar-btn {isRoughMode ? 'active' : ''}"
            title="Hand-Drawn Style (R)"
            onclick={toggleRoughMode}>
            <RoughIcon class="size-4" />
          </Button>
          <Button
            variant="ghost"
            size="icon"
            class="toolbar-btn {isGridVisible ? 'active' : ''}"
            title="Show Grid (G)"
            onclick={toggleGrid}>
            <Grid3x3 class="size-4" />
          </Button>
        </div>

        <div class="divider-v hidden lg:block"></div>

        <!-- Layout -->
        <div class="hidden flex-shrink-0 items-center gap-1 lg:flex">
          <div class="toolbar-group">
            <Button
              variant="ghost"
              size="icon"
              class="toolbar-btn {currentLayout === 'dagre' ? 'active' : ''}"
              title="Dagre Layout"
              onclick={() => handleLayoutChange('dagre')}>
              <Layers class="size-4" />
            </Button>
            <Button
              variant="ghost"
              size="icon"
              class="toolbar-btn {currentLayout === 'elk' ? 'active' : ''}"
              title="ELK Layout"
              onclick={() => handleLayoutChange('elk')}>
              <LayoutGrid class="size-4" />
            </Button>
          </div>
        </div>

        <div class="divider-v hidden xl:block"></div>

        <!-- Export -->
        <div class="toolbar-group hidden flex-shrink-0 xl:flex">
          <Button
            variant="ghost"
            size="icon"
            class="toolbar-btn"
            title="Export SVG (Ctrl+S)"
            onclick={handleExport}>
            <Download class="size-4" />
          </Button>
        </div>

        <!-- Right: Zoom Controls -->
        <div class="ml-auto flex flex-shrink-0 items-center gap-1 sm:gap-1.5">
          <div class="toolbar-group">
            <Button
              variant="ghost"
              size="icon"
              class="toolbar-btn"
              title="Zoom Out (-)"
              onclick={() => {
                panZoomState.zoomOut();
                zoomLevel = Math.max(25, zoomLevel - 10);
              }}>
              <ZoomOut class="size-4" />
            </Button>
            <Button
              variant="ghost"
              size="icon"
              class="toolbar-btn"
              title="Zoom In (+)"
              onclick={() => {
                panZoomState.zoomIn();
                zoomLevel = Math.min(400, zoomLevel + 10);
              }}>
              <ZoomIn class="size-4" />
            </Button>
            <Button
              variant="ghost"
              size="icon"
              class="toolbar-btn hidden sm:flex"
              title="Reset View (0)"
              onclick={() => {
                panZoomState.reset();
                zoomLevel = 100;
              }}>
              <RotateCcw class="size-4" />
            </Button>
            <Button
              variant="ghost"
              size="icon"
              class="toolbar-btn hidden md:flex"
              title="Fullscreen"
              onclick={() => {
                if (document.fullscreenElement) document.exitFullscreen();
                else document.documentElement.requestFullscreen();
              }}>
              <Expand class="size-4" />
            </Button>
          </div>
        </div>
      </div>

      <!-- Diagram View -->
      <div class="relative flex-1 overflow-hidden">
        <View
          {panZoomState}
          shouldShowGrid={$stateStore.grid}
          bind:isRendering={isViewRendering}
          bind:renderError={viewRenderError} />
        <!-- Canvas Panels -->
        <ColorPanel bind:open={isColorPanelOpen} />
        <IconPanel bind:open={isIconPanelOpen} />
      </div>

      <!-- Status Bar -->
      <div
        class="flex h-7 items-center justify-between border-t border-border/30 bg-muted/30 px-3 text-[10px]">
        <div class="flex items-center gap-2">
          <div class="flex items-center gap-1">
            {#if isViewRendering}
              <span class="size-1.5 animate-pulse rounded-full bg-amber-500"></span>
              <span class="font-medium text-amber-600 dark:text-amber-400">Rendering…</span>
            {:else if viewRenderError}
              <span class="size-1.5 rounded-full bg-red-500"></span>
              <span
                class="max-w-[200px] truncate font-medium text-red-600 dark:text-red-400"
                title={viewRenderError}>Error</span>
            {:else}
              <span class="size-1.5 rounded-full bg-emerald-500"></span>
              <span class="font-medium text-muted-foreground">Ready</span>
            {/if}
          </div>
          <div class="h-3 w-px bg-border/40"></div>
          <span class="text-muted-foreground"
            >Zoom: <span class="font-mono font-medium text-foreground/70">{zoomLevel}%</span></span>
          {#if selectedElementLabel}
            <div class="h-3 w-px bg-border/40"></div>
            <div class="flex items-center gap-1">
              {#if selectedElementType === 'node'}
                <Square class="size-2.5 text-indigo-500" />
              {:else}
                <ArrowLeftRight class="size-2.5 text-indigo-500" />
              {/if}
              <span class="max-w-[240px] truncate font-medium text-indigo-600 dark:text-indigo-400">
                {#if selectedElementType === 'node' && selectedElementNodeName && selectedElementLabel && selectedElementNodeName !== selectedElementLabel}
                  <span class="font-mono text-muted-foreground">{selectedElementNodeName}</span>
                  <span class="text-border/60">·</span>
                  {selectedElementLabel}
                {:else}
                  {selectedElementLabel}
                {/if}
              </span>
            </div>
          {/if}
        </div>
        <div class="flex items-center gap-2">
          {#if documentationURL.key}
            <span
              class="hidden rounded bg-muted/60 px-1.5 py-0.5 font-medium text-muted-foreground capitalize md:inline"
              >{documentationURL.key}</span>
          {/if}
          <span
            class="hidden rounded bg-muted/60 px-1.5 py-0.5 font-medium text-muted-foreground capitalize sm:inline"
            >Layout: {currentLayout === 'elk'
              ? 'Optimized'
              : currentLayout === 'dagre'
                ? 'Classic'
                : currentLayout}</span>
        </div>
      </div>
    </div>

    <!-- Secondary Sidebar positioned on left -->
    {#if isSecondarySidebarVisible && secondarySidebarPosition === 'left'}
      <div class="relative flex-shrink-0" style="width: {secondarySidebarWidth}px;">
        {#if secondarySidebarContent === 'tools'}
          <PrimarySidebar onFileOpen={handleFileOpen} />
        {:else if secondarySidebarContent === 'code'}
          <SecondarySidebar>
            <div class="flex h-full flex-col">
              <div class="flex-1 overflow-hidden">
                <Editor
                  onUpdate={(code) => {
                    updateCodeStore({ code });
                    ensureFileExists();
                    autosaveStore.markChanged();
                  }}
                  isMobile={width < 768}
                  sendChatMessage={async (message) => {
                    if (chatComponent) {
                      return await chatComponent.sendMessageExternal(message);
                    }
                    return false;
                  }} />
              </div>
            </div>
          </SecondarySidebar>
        {:else if secondarySidebarContent === 'chat'}
          <SecondarySidebar
            onNewChat={handleNewChat}
            onClearChat={handleClearChat}
            onSelectConversation={(id) => console.log('Switch to conversation:', id)}
            sendChatMessage={handleSendChatMessage}>
            <div class="flex h-full flex-col">
              <div class="flex-1 overflow-hidden">
                <Chat bind:this={chatComponent} />
              </div>
            </div>
          </SecondarySidebar>
        {/if}

        <!-- Resize Handle for Secondary Sidebar -->
        <!-- svelte-ignore a11y_no_noninteractive_element_interactions -->
        <div
          class="group absolute top-0 right-0 z-10 h-full w-1 cursor-ew-resize bg-transparent transition-colors hover:bg-primary/20 {isResizingSecondary
            ? 'bg-primary/40'
            : ''}"
          role="separator"
          aria-orientation="vertical"
          aria-label="Resize secondary sidebar"
          onmousedown={startResizeSecondary}>
          <div
            class="absolute top-1/2 right-1/2 translate-x-1/2 -translate-y-1/2 opacity-0 transition-opacity group-hover:opacity-100">
            <div
              class="flex h-12 w-6 items-center justify-center rounded-full bg-black text-white shadow-lg">
              <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
              </svg>
            </div>
          </div>
        </div>
      </div>
    {/if}

    <!-- Secondary Sidebar (can be positioned left or right) -->
    {#if isSecondarySidebarVisible}
      {#if secondarySidebarPosition === 'right'}
        <div class="relative flex-shrink-0" style="width: {secondarySidebarWidth}px;">
          {#if secondarySidebarContent === 'tools'}
            <PrimarySidebar onFileOpen={handleFileOpen} />
          {:else if secondarySidebarContent === 'code'}
            <SecondarySidebar>
              <div class="flex h-full flex-col">
                <div class="flex-1 overflow-hidden">
                  <Editor
                    onUpdate={(code) => {
                      updateCodeStore({ code });
                      ensureFileExists();
                      autosaveStore.markChanged();
                    }}
                    isMobile={width < 768}
                    sendChatMessage={async (message) => {
                      if (chatComponent) {
                        return await chatComponent.sendMessageExternal(message);
                      }
                      return false;
                    }} />
                </div>
              </div>
            </SecondarySidebar>
          {:else if secondarySidebarContent === 'chat'}
            <SecondarySidebar
              onNewChat={handleNewChat}
              onClearChat={handleClearChat}
              onSelectConversation={(id) => console.log('Switch to conversation:', id)}
              sendChatMessage={handleSendChatMessage}>
              <div class="flex h-full flex-col">
                <div class="flex-1 overflow-hidden">
                  <Chat bind:this={chatComponent} />
                </div>
              </div>
            </SecondarySidebar>
          {/if}

          <!-- Resize Handle for Secondary Sidebar (right position) -->
          <!-- svelte-ignore a11y_no_noninteractive_element_interactions -->
          <div
            class="group absolute top-0 left-0 z-10 h-full w-1 cursor-ew-resize bg-transparent transition-colors hover:bg-primary/20 {isResizingSecondary
              ? 'bg-primary/40'
              : ''}"
            role="separator"
            aria-orientation="vertical"
            aria-label="Resize secondary sidebar"
            onmousedown={startResizeSecondary}>
            <div
              class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 transition-opacity group-hover:opacity-100">
              <div
                class="flex h-12 w-6 items-center justify-center rounded-full bg-black text-white shadow-lg">
                <svg
                  class="h-4 w-4 text-white"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
                </svg>
              </div>
            </div>
          </div>
        </div>
      {/if}
    {/if}
  </div>
</div>

<!-- Settings Modal -->
<SettingsModal bind:open={isSettingsModalOpen} onOpenChange={(v) => (isSettingsModalOpen = v)} />

<!-- Auth Modal (voluntary) -->
<AuthModal open={isAuthModalOpen} onClose={() => (isAuthModalOpen = false)} />

<!-- Refill Gems Modal -->
<RefillGemsModal open={isRefillGemsOpen} onClose={() => (isRefillGemsOpen = false)} />

<!-- Keyboard Shortcuts Modal -->
{#if isShortcutsModalOpen}
  <!-- svelte-ignore a11y_no_static_element_interactions -->
  <div
    class="fixed inset-0 z-[100] flex items-center justify-center bg-black/50 backdrop-blur-sm"
    onclick={() => (isShortcutsModalOpen = false)}
    onkeydown={(e) => e.key === 'Escape' && (isShortcutsModalOpen = false)}>
    <!-- svelte-ignore a11y_no_static_element_interactions -->
    <div
      class="mx-4 w-full max-w-md rounded-xl border border-border bg-card p-5 shadow-2xl"
      onclick={(e) => e.stopPropagation()}>
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-foreground">Keyboard Shortcuts</h2>
        <button
          type="button"
          class="rounded-md p-1 text-muted-foreground hover:bg-muted hover:text-foreground"
          onclick={() => (isShortcutsModalOpen = false)}>
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="space-y-3">
        <div>
          <h3
            class="mb-1.5 text-[10px] font-semibold tracking-wider text-muted-foreground uppercase">
            Tools
          </h3>
          <div class="space-y-1">
            {#each [['V', 'Select tool'], ['P', 'Pan tool'], ['D', 'Draw tool'], ['G', 'Toggle grid'], ['R', 'Rough mode']] as [key, label]}
              <div class="flex items-center justify-between rounded-md px-2 py-1 hover:bg-muted/50">
                <span class="text-xs text-foreground/80">{label}</span>
                <kbd
                  class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[10px] text-muted-foreground"
                  >{key}</kbd>
              </div>
            {/each}
          </div>
        </div>
        <div>
          <h3
            class="mb-1.5 text-[10px] font-semibold tracking-wider text-muted-foreground uppercase">
            Edit
          </h3>
          <div class="space-y-1">
            {#each [['⌘Z', 'Undo'], ['⌘⇧Z', 'Redo'], ['⌘S', 'Export'], ['⌘O', 'Import'], ['Del', 'Delete selected']] as [key, label]}
              <div class="flex items-center justify-between rounded-md px-2 py-1 hover:bg-muted/50">
                <span class="text-xs text-foreground/80">{label}</span>
                <kbd
                  class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[10px] text-muted-foreground"
                  >{key}</kbd>
              </div>
            {/each}
          </div>
        </div>
        <div>
          <h3
            class="mb-1.5 text-[10px] font-semibold tracking-wider text-muted-foreground uppercase">
            View
          </h3>
          <div class="space-y-1">
            {#each [['⌘+', 'Zoom in'], ['⌘-', 'Zoom out'], ['⌘0', 'Reset zoom'], ['⌘B', 'Toggle sidebar'], ['?', 'This dialog']] as [key, label]}
              <div class="flex items-center justify-between rounded-md px-2 py-1 hover:bg-muted/50">
                <span class="text-xs text-foreground/80">{label}</span>
                <kbd
                  class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[10px] text-muted-foreground"
                  >{key}</kbd>
              </div>
            {/each}
          </div>
        </div>
      </div>
    </div>
  </div>
{/if}
